          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.collectionVariables.set(\"token\", response.data.token);\r",
                  "pm.collectionVariables.set(\"user_id\", response.data.user.id);\r",
                  "\r",
                  "pm.test(\"Token recibido\", function () {\r",
                  "    pm.expect(response.data.token).to.be.a(\"string\");\r",
                  "});"
